{
    "breadcrumbs.enabled": true,
    "telemetry.telemetryLevel": "off",
    "editor.accessibilitySupport": "off",
    "editor.copyWithSyntaxHighlighting": false,
    "editor.minimap.enabled": false,
    "editor.folding": false,
    "editor.fontLigatures": false,
    "editor.lineNumbers": "on",
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "line-thin",
    "editor.cursorWidth": 2,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.wordWrap": "on",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.inlineSuggest.enabled": true,
    "editor.rulers": [
        {"column":  80, "color": "#282C34"},
        {"column":  100, "color": "#282C34"}
    ],
    "workbench.startupEditor": "newUntitledFile",
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.enablePreview": false,
    "files.defaultLanguage": "markdown",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "security.workspace.trust.untrustedFiles": "open",
    "update.showReleaseNotes": false,
    "r.bracketedPaste": true,
    "r.removeLeadingComments": true,
    "r.rpath.mac": "/usr/local/bin/R",
    "r.rterm.mac": "/opt/homebrew/bin/radian",
    "r.rterm.option": [
        "--no-save",
        "--no-restore",
        "--r-binary=/usr/local/bin/R"
    ],
    "r.rmarkdown.codeLensCommands": [
        "r.runCurrentChunk",
        "r.runAllChunks"
    ],
    "[r]": {
        "editor.defaultFormatter": "REditorSupport.r",
    },
    "r.session.levelOfObjectDetail": "Detailed",
    "r.session.data.rowLimit": 1000,
    "r.plot.useHttpgd": true,
    "r.lsp.diagnostics": true,
    "r.lsp.enabled": true,
    "window.commandCenter": false,
    "extensions.ignoreRecommendations": true,
    "explorer.confirmDragAndDrop": false,
    "git.openRepositoryInParentFolders": "always",
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.12",
    "python.experiments.enabled": false,
    "rainbow_csv.align_in_scratch_file": true,
    "explorer.confirmDelete": false,
    "spellright.language": [
        "en"
    ],
    "spellright.documentTypes": [
        "markdown",
        "latex",
        "plaintext"
    ]
}
